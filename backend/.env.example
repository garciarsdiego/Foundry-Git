PORT=3001
DATABASE_PATH=./foundry.db

# GitHub Personal Access Token (for repo sync, branch & PR creation)
# This is the fallback token used when no connection-specific env var is set
GITHUB_TOKEN=

# GitHub App credentials (optional — use instead of GITHUB_TOKEN for app-based auth)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_INSTALLATION_ID=

# Example provider API key env var names (set your real keys with these names)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
