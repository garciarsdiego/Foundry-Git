PORT=3001
DATABASE_PATH=./foundry.db

# Authentication (optional — if not set, auth is disabled for local dev)
# Set a strong password to enable JWT-based authentication
FOUNDRY_ADMIN_PASSWORD=
# Signing secret for JWT tokens (auto-generated default in dev — set explicitly in production)
FOUNDRY_JWT_SECRET=

# GitHub Personal Access Token (for repo sync, branch & PR creation)
# This is the fallback token used when no connection-specific env var is set
GITHUB_TOKEN=

# GitHub App credentials (optional — use instead of GITHUB_TOKEN for app-based auth)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_INSTALLATION_ID=

# Example provider API key env var names (set your real keys with these names)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional: customize OpenRouter attribution headers
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
